{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loomen",
  "version": "0.1.0",
  "identifier": "org.loomen.notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loomen",
        "width": 1440,
        "height": 900,
        "minWidth": 920,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "loomen"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Ömer Faruk Erol",
    "copyright": "© 2026 Ömer Faruk Erol",
    "category": "Productivity",
    "shortDescription": "Yerel çalışan not, planlayıcı ve Pomodoro uygulaması",
    "longDescription": "Loomen; notlarını düz Markdown dosyaları olarak kendi klasöründe tutan, tamamen çevrimdışı çalışan bir kişisel bilgi yönetimi uygulamasıdır. Çift yönlü bağlantı, graf görünümü, günlük planlayıcı, takvim ve Pomodoro içerir.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "languages": [
          "Turkish",
          "English"
        ],
        "installMode": "perMachine"
      }
    }
  }
}
