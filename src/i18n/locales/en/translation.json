  "help": {
    "title": "Help & Guide",
    "subtitle": "Learn Loomen in a few minutes — everything is simple and fully local.",
    "filesTitle": "Your notes are your files",
    "filesBody": "Every note is a plain .md (Markdown) file on your computer. No internet or server; everything stays on your device. Even if you delete a note it first goes to the Trash (kept for 30 days), so you won't lose it by accident.",
    "createTitle": "Creating notes and quick switching",
    "createBody": "Press ⌘N to create a new note. Press ⌘O to jump to or search for an existing one. Use the Explorer on the left to browse your folders, and drag notes to reorganize them.",
    "linksTitle": "Links",
    "linksBody": "To connect two notes, type the note's name inside double square brackets in your text. It becomes a clickable link and shows up in the Graph as a line between two dots. This is how you build a web between your notes.",
    "linksExamplePre": "Example:",
    "tagsTitle": "Tags",
    "tagsBody": "Write a tag starting with # inside a note (e.g. #journal). Notes that share a tag become related. In the Graph, tags appear as green nodes that connect every note using them.",
    "graphTitle": "Graph view",
    "graphBody": "The Graph is a map of your notes: dots are notes, lines are links, green nodes are tags. Drag to move around, scroll to zoom, click a dot to open the note. Use + / − on the right to zoom and the target icon to fit the graph to the screen; the settings icon toggles tags, orphan notes and arrows.",
    "openGraph": "Open the graph",
    "plannerTitle": "Planner, Calendar & Pomodoro",
    "plannerBody": "The Planner keeps your daily tasks, calendar and focus timer (Pomodoro) in one place. The 'Today's Note' button at the top opens today's note. Complete tasks with a checkbox, give them dates, and drag to reorder. Focus while the Pomodoro runs, then rest on the break.",
    "drawTitle": "Drawing & Reports",
    "drawBody": "The Draw screen lets you make freehand sketches and diagrams (Excalidraw). The Reports screen shows summary statistics about your notes and tasks.",
    "syncTitle": "Backup & Sync",
    "syncBody": "Loomen has no server of its own. Because your notes are plain files, you can sync them across devices with iCloud Drive, Syncthing or Git. Backing up your vault folder means backing up all of your data.",
    "shortcutsTitle": "Keyboard shortcuts",
    "scNew": "New note",
    "scOpen": "Go to file / search",
    "scClose": "Close (detail or window)",
    "safetyTitle": "Your data is safe",
    "safetyBody": "Loomen never touches your notes' content silently. Moving and renaming preserve the file exactly; deleting is always reversible. The single source of truth is the file on your disk.",
    "exampleNoteA": "Ideas",
    "exampleNoteThis": "This note",
    "exampleTag": "journal"
